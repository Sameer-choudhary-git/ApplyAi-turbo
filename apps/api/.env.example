# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/applyai

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# R2/Cloudflare Storage Configuration
R2_ENDPOINT_URL=https://your-account.r2.cloudflarecontent.com
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=your-bucket
R2_PUBLIC_URL=https://your-public-url

# Encryption Configuration
COOKIE_ENCRYPTION_KEY=your-32-byte-hex-encoded-key

# Public API URL
PUBLIC_API_URL=http://localhost:3000
