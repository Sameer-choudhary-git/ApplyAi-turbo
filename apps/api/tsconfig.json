{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "outDir": "dist",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "@applyai/config": ["../../packages/config/index.ts"],
      "@applyai/db": ["../../packages/db/index.ts"],
      "@applyai/utils": ["../../packages/utils/index.ts"],
      "@applyai/types": ["../../packages/types/index.ts"]
    }
  },
  "include": ["src"]
}