    "company": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "work_mode": {
      "type": "string"
    },
    "stipend": {
      "type": "string"
    },
    "deadline": {
      "type": "string",
      "format": "date"
    },
