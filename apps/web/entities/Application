{
  "name": "Application",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "company": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "internship",
        "job",
        "hackathon",
        "competition"
      ]
    },
    "platform": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "applied",
        "under_review",
        "shortlisted",
        "interview_scheduled",
        "accepted",
        "rejected",
        "withdrawn"
      ],
      "default": "applied"
    },
    "applied_date": {
      "type": "string",
      "format": "date"
    },
    "deadline": {
      "type": "string",
      "format": "date"
    },
    "stipend": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "work_mode": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "success_probability": {
      "type": "number"
    },
    "interview_date": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "title",
    "company"
  ]
}