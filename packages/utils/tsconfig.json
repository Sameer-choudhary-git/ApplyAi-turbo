{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": ".",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "composite": true,
    "types": ["node"],
    "paths": {
      "@applyai/config": ["../config/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../config" }
  ]
}