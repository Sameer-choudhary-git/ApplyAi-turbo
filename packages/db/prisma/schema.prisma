generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Scraped data ──────────────────────────────────────────────────────────────

model unstop_internships {
  id         String  @id @default(cuid())
  title      String
  company    String
  link       String  @unique
  stipend    String?
  experience String?
  type       String? // "Full Time" | "Part Time"
  location   String?
  skills     Json    @default("[]")
  tags       Json    @default("[]")
  postedDate String?
  daysLeft   String?

  isActive  Boolean   @default(true)
  expiresAt DateTime?

  scrapedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  metadata Json?
}

// ─── Users ────────────────────────────────────────────────────────────────────

model users {
  id String @id

  fullName    String
  email       String  @unique
  phone       String?
  location    String?
  bio         String?
  resumeUrl   String?
  linkedinUrl String?
  githubUrl   String?

  isOnboarded Boolean   @default(false)
  onboardedAt DateTime?

  // Relations
  education        user_education[]
  experience       user_experience[]
  skills           user_skills[]
  preferences      user_preferences?
  platformSessions user_platform_sessions[]

  // ── Job-enable flags ──────────────────────────────────────────────────────
  // One boolean per flag in enableJobsConfig.
  // Add a new flag here whenever you add one to the config.
  isUnstopInternshipEnabled Boolean @default(false)
  isUnstopJobEnabled        Boolean @default(false) // was missing — now added
  isCommudleEventEnabled    Boolean @default(false)

  // Scheduling
  lastQueuedAt    DateTime?
  queueCountToday Int       @default(0)
  lastQueueReset  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Profile sub-tables ───────────────────────────────────────────────────────

model user_education {
  id     String @id @default(cuid())
  userId String
  user   users  @relation(fields: [userId], references: [id], onDelete: Cascade)

  institution  String
  degree       String?
  fieldOfStudy String?
  gpa          String?
  startYear    Int?
  endYear      Int?

  createdAt DateTime @default(now())
}

model user_experience {
  id     String @id @default(cuid())
  userId String
  user   users  @relation(fields: [userId], references: [id], onDelete: Cascade)

  company     String
  role        String?
  duration    String?
  description String?

  createdAt DateTime @default(now())
}

model user_skills {
  id     String @id @default(cuid())
  userId String
  user   users  @relation(fields: [userId], references: [id], onDelete: Cascade)

  skill String

  @@unique([userId, skill])
}

// ─── Preferences ─────────────────────────────────────────────────────────────

model user_preferences {
  id     String @id @default(cuid())
  userId String @unique
  user   users  @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Platform targeting ────────────────────────────────────────────────────
  workModes        Json @default("[]") // ["Remote", "Hybrid", "On-site"]
  opportunityTypes Json @default("[]") // ["Internship", "Full-time Job", ...]
  platforms        Json @default("[]") // ["LinkedIn", "Unstop", ...]

  // ── Location & compensation ───────────────────────────────────────────────
  preferredLocations Json    @default("[]") // ["Bangalore", "Remote", ...]
  minStipend         Int     @default(0)    // monthly in INR

  // ── Role keywords ─────────────────────────────────────────────────────────
  rolesOfInterest Json @default("[]") // ["Frontend Developer", ...]
  industries      Json @default("[]") // ["Technology", "Fintech", ...]

  // ── Automation ────────────────────────────────────────────────────────────
  autoApply       Boolean @default(false)
  dailyApplyLimit Int     @default(10)

  // ── Platform-specific settings (stored as JSONB blobs) ───────────────────
  // Shape for unstopPreferences:
  //   { competition_types: string[], prize_minimum: number }
  unstopPreferences   Json?
  commudlePreferences Json?   // ✅ ADD THIS


  // Add more platform-specific blobs as needed:
  // commudlePreferences Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Platform sessions (cookies) ─────────────────────────────────────────────

model user_platform_sessions {
  id     String @id @default(cuid())
  userId String
  user   users  @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform        String    // "unstop", "commudle", etc.
  encryptedCookie String    @db.Text

  isActive       Boolean   @default(true)
  lastVerifiedAt DateTime?
  expiresAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, platform])
}

// ─── Setup tokens ────────────────────────────────────────────────────────────

model unstop_setup_tokens {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}
