// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model unstop_internships {
  id           String    @id @default(cuid())
  title        String
  company      String
  link         String    @unique
  stipend      String?
  experience   String?
  type         String?   // "Full Time" | "Part Time"
  location     String?
  skills       Json      @default("[]")
  tags         Json      @default("[]")
  postedDate   String?
  daysLeft     String?

  // lifecycle fields
  isActive     Boolean   @default(true)
  expiresAt    DateTime?

  // audit fields
  scrapedAt    DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // escape hatch for future/unknown fields
  metadata     Json?
}

model users {
  id            String   @id @default(cuid())
  
  // basic info
  fullName      String
  email         String   @unique
  phone         String?
  location      String?
  bio           String?
  resumeUrl     String?  // s3/cloudflare link
  linkedinUrl   String?
  githubUrl     String?

  // onboarding state
  isOnboarded   Boolean  @default(false)
  onboardedAt   DateTime?

  // relations
  education     user_education[]
  experience    user_experience[]
  skills        user_skills[]
  preferences   user_preferences?
  platformSessions user_platform_sessions[]

  isUnstopInternshipEnabled Boolean @default(false)
  isCommudleEventEnabled    Boolean @default(false)

  // scheduling fields
  lastQueuedAt DateTime?
  queueCountToday Int @default(0)
  lastQueueReset DateTime?


  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model user_education {
  id          String   @id @default(cuid())
  userId      String
  user        users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  institution String
  degree      String?
  fieldOfStudy String?
  gpa         String?
  startYear   Int?
  endYear     Int?

  createdAt   DateTime @default(now())
}

model user_experience {
  id          String   @id @default(cuid())
  userId      String
  user        users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  company     String
  role        String?
  duration    String?
  description String?

  createdAt   DateTime @default(now())
}

model user_skills {
  id        String  @id @default(cuid())
  userId    String
  user      users   @relation(fields: [userId], references: [id], onDelete: Cascade)

  skill     String

  @@unique([userId, skill])
}

model user_preferences {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // work mode — multiple allowed so Json array
  workModes       Json     @default("[]")  // ["Remote", "Hybrid", "On-site"]

  // opportunity types
  opportunityTypes Json    @default("[]")  // ["Internship", "Full-time Job", ...]

  // platforms user wants to apply on
  platforms       Json     @default("[]")  // ["LinkedIn", "Unstop", ...]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// this is where you store cookies/session data per platform
model user_platform_sessions {
  id             String   @id @default(cuid())
  userId         String
  user           users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform       String   // "unstop", "linkedin", etc

  // 🔐 actual cookie stored here (encrypted)
  encryptedCookie String  @db.Text

  // optional metadata
  isActive       Boolean  @default(true)
  lastVerifiedAt DateTime?
  expiresAt      DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, platform])
}